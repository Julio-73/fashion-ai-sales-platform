# =============================================================================
# AI Sales Agent SaaS — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_ENV=local
APP_NAME="AI Sales Agent SaaS"
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/ai_sales_agent_saas

# --- Redis (optional — used for rate limiting, caching) ---
# Leave empty for in-memory fallback (single-instance only)
REDIS_URL=

# --- JWT Authentication ---
JWT_ISSUER=ai-sales-agent-saas
JWT_AUDIENCE=ai-sales-agent-dashboard
JWT_ALGORITHM=HS256
# !!! IMPORTANT: Generate a NEW random secret for production:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OpenAI (AI features) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
