APP_ENV=local
APP_NAME="AI Sales Agent SaaS"
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_sales_agent_saas

JWT_ISSUER=ai-sales-agent-saas
JWT_AUDIENCE=ai-sales-agent-dashboard
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-this-local-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

