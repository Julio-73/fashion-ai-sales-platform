# =============================================================================
# AI Sales Agent SaaS — Enterprise Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.
#
# Profiles:
#   APP_ENV=local       → Development, reload on changes, verbose logging
#   APP_ENV=testing     → CI/QA, no reload, test database
#   APP_ENV=production  → Production, workers, minimal logging, security headers
# =============================================================================

# --- Application ---
APP_ENV=local
APP_NAME="AI Sales Agent SaaS"
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# Production: use a strong, unique password and restrict access by IP
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/ai_sales_agent_saas

# --- Redis (required for production multi-instance) ---
# Used for: rate limiting, caching, session store, AI task queue
# Format: redis://USER:PASSWORD@HOST:PORT/DB
# Leave empty for in-memory fallback (single-instance dev only — NOT for production)
REDIS_URL=

# --- JWT Authentication ---
JWT_ISSUER=ai-sales-agent-saas
JWT_AUDIENCE=ai-sales-agent-dashboard
JWT_ALGORITHM=HS256
# !!! IMPORTANT: Generate a NEW random 64-char secret for each environment:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
# Separate key for admin panel JWT (must be different from JWT_SECRET_KEY)
ADMIN_JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OpenAI (AI Sales Agent features) ---
# Without this key, AI features (recommendations, intents, automation) will fail.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# --- WhatsApp Integration ---
# Encryption key for storing WhatsApp access tokens at rest.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WHATSAPP_ENCRYPTION_KEY=

# --- Database Pool (production tuning) ---
# Only set these if you need to override the defaults.
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# --- Server (production) ---
# HOST=0.0.0.0
# PORT=8000
# WORKERS=4
# TIMEOUT_KEEPALIVE=5
